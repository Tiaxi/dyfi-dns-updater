# Required: dy.fi credentials
DYFI_USER=your_email@example.com
DYFI_PASS=your_dyfi_password
DYFI_DOMAIN=yourdomain.dy.fi

# Optional: Timing
# CHECK_INTERVAL_MINUTES=5
# FORCE_UPDATE_DAYS=2

# Optional: Email notifications (disabled by default)
# When using Gmail, generate an App Password:
# https://myaccount.google.com/apppasswords
# EMAIL_ENABLED=true
# EMAIL_USER=your_gmail@gmail.com
# EMAIL_PASS=your_gmail_app_password
# EMAIL_RECIPIENT=notify@example.com
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# Optional: Log file (default: stdout only, set to enable file logging)
# LOG_FILE=dyfi_dns_updater.log
